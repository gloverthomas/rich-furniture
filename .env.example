# Resend (enquiry form + newsletter signup)
# Without these, both forms simulate success in development and return 503 in production.
RESEND_API_KEY=
# Studio inbox that receives bespoke enquiries
ENQUIRY_TO_EMAIL=hello@tomglover.com.au
# Verified sender; the resend.dev sender works for testing before the domain is verified
ENQUIRY_FROM_EMAIL="ARV Studio <onboarding@resend.dev>"
# Resend Audience that collects footer signups (Resend dashboard -> Audiences)
RESEND_AUDIENCE_ID=

# Used for metadataBase (Open Graph absolute URLs) once deployed
NEXT_PUBLIC_SITE_URL=
